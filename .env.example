# ── Database ──────────────────────────────────────────────────────────────────
# MariaDB root password (used only during container initialization)
MYSQL_ROOT_PASSWORD=change_this_root_password

# Database name, user, and password (used by tv_site and playout containers)
DB_NAME=tv_stats
DB_USER=logger
DB_PASS=change_this_db_password

# ── Web Application ────────────────────────────────────────────────────────────
# Express session secret — must be a long random string in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string

# ── Server Network ─────────────────────────────────────────────────────────────
# The LAN IP address of this server.
# Used in:
#   - UDP discovery replies (TV-SERVER:http://<ADDR>:3000)
#   - TSDuck SDT beacon injection (SRV:http://<ADDR>:3000)
#   - Playout container interface binding
ADDR=192.168.1.100

# ── Media Paths (inside the tv_site container) ────────────────────────────────
# Base path for ad video files (must match the volume mount in docker-compose.yml)
ADS_BASE_PATH=/opt/tv_station/media/ads/

# ── Legacy / Optional ─────────────────────────────────────────────────────────
# ErsatzTV integration (not used in current version, can be left as-is)
ERSATZTV_URL=http://127.0.0.1:8409
ERSATZTV_CHANNEL_ID=1
